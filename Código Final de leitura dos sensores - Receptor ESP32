#include <WiFi.h>        // Biblioteca para conexão Wi-Fi do ESP32
#include <PubSubClient.h> // Biblioteca para comunicação MQTT
#include <EBYTE.h>        // Biblioteca para controle do módulo LoRa EBYTE

// --- LoRa (Ebyte) ---
#define PIN_RX 16   // RX do ESP32 <- TX do módulo
#define PIN_TX 17   // TX do ESP32 -> RX do módulo
#define PIN_M0 5    // Pino de controle de modo M0
#define PIN_M1 18   // Pino de controle de modo M1
#define PIN_AUX 4   // Pino para verificar estado do módulo

#pragma pack(push, 1)  // Desativa o alinhamento automático de memória para garantir que a struct seja recebida sem bytes extras
struct DATA {
  uint32_t Count;    // Contador de pacotes recebidos (4 bytes)
  float TensaoVcc;   // Valor da tensão recebida do transmissor (4 bytes)
  float CorrenteDC;  // Valor da corrente recebida do transmissor (4 bytes)
  uint8_t Checksum;  // Byte de verificação de integridade dos dados (1 byte)
};
#pragma pack(pop)  // Restaura o alinhamento de memória padrão

DATA MyData;  // Variável que armazena os dados recebidos
EBYTE Transceiver(&Serial2, PIN_M0, PIN_M1, PIN_AUX);  // Cria objeto do módulo LoRa utilizando a Serial2 do ESP32

// Calcula o checksum somando todos os bytes da struct exceto o próprio byte de checksum
uint8_t calculateChecksum(DATA* data) {
  uint8_t* bytes = (uint8_t*)data;  // Interpreta a struct como um array de bytes
  uint8_t sum = 0;                  // Acumulador da soma
  for (size_t i = 0; i < sizeof(DATA)-1; i++) {  // Percorre todos os bytes exceto o último (Checksum)
    sum += bytes[i];  // Acumula cada byte
  }
  return sum;  // Retorna a soma calculada
}

void sendAck(uint32_t count) {
  String ack = "ACK:" + String(count) + "\n";  // Monta a mensagem de confirmação com o número do pacote recebido
  Serial2.print(ack);  // Envia o ACK de volta ao Arduino via LoRa
}

// --- Wi-Fi e MQTT ---
const char* ssid = "VIVOFIBRA-9A51";       // Nome da rede Wi-Fi
const char* password = "hFWNH4SrUk";       // Senha da rede Wi-Fi
const char* mqtt_server = "192.168.15.4";  // Endereço IP do broker MQTT

WiFiClient Projeto_Tcc;          // Cria objeto de conexão Wi-Fi
PubSubClient client(Projeto_Tcc); // Cria objeto do cliente MQTT utilizando a conexão Wi-Fi

void setup_wifi() {
  Serial.print("Conectando ao Wi-Fi...");
  WiFi.mode(WIFI_STA);          // Define o ESP32 como estação Wi-Fi (cliente)
  WiFi.begin(ssid, password);   // Inicia a conexão com a rede Wi-Fi
  while (WiFi.status() != WL_CONNECTED) {  // Aguarda até a conexão ser estabelecida
    delay(500);
    Serial.print(".");  // Exibe progresso da conexão no monitor serial
  }
  Serial.println("\nWi-Fi conectado. IP: ");
  Serial.println(WiFi.localIP());  // Exibe o endereço IP atribuído ao ESP32
}

void reconnect_mqtt() {
  while (!client.connected()) {  // Tenta reconectar enquanto não estiver conectado ao broker
    Serial.print("Conectando ao MQTT...");
    if (client.connect("Projeto_Tcc")) {  // Tenta conectar ao broker com o identificador "Projeto_Tcc"
      Serial.println("conectado!");
    } else {
      Serial.print("falhou, rc=");
      Serial.print(client.state());  // Exibe o código de erro da tentativa de conexão
      Serial.println(" tentando novamente em 5s...");
      delay(5000);  // Aguarda 5 segundos antes de tentar novamente
    }
  }
}

// --- Setup ---
void setup() {
  Serial.begin(9600);  // Inicializa comunicação serial com o PC a 9600 bps
  Serial2.begin(9600, SERIAL_8N1, PIN_RX, PIN_TX);  // Inicializa a Serial2 do ESP32 a 9600 bps com 8 bits de dados, sem paridade e 1 bit de parada

  pinMode(PIN_M0, OUTPUT);    // Configura M0 como saída
  pinMode(PIN_M1, OUTPUT);    // Configura M1 como saída
  digitalWrite(PIN_M0, LOW);  // Define M0 como LOW
  digitalWrite(PIN_M1, LOW);  // Define M1 como LOW, colocando o módulo em modo normal de operação

  delay(1000);  // Aguarda 1 segundo para estabilização do módulo
  Serial.println("Receptor de Tensão LoRa inicializado");  // Confirma inicialização no monitor serial

  setup_wifi();                      // Inicia a conexão com a rede Wi-Fi
  client.setServer(mqtt_server, 1883);  // Define o endereço e porta do broker MQTT
}

// --- Loop ---
void loop() {
  if (!client.connected()) {  // Verifica se o cliente MQTT está conectado
    reconnect_mqtt();          // Reconecta ao broker caso a conexão tenha sido perdida
  }
  client.loop();  // Mantém a conexão MQTT ativa e processa mensagens recebidas

  if (Serial2.available() >= sizeof(DATA)) {  // Verifica se há bytes suficientes disponíveis na serial para formar um pacote completo
    uint8_t buffer[sizeof(DATA)];  // Cria um buffer temporário do tamanho da struct
    size_t bytesRead = Serial2.readBytes(buffer, sizeof(DATA));  // Lê os bytes da serial para o buffer e armazena a quantidade lida

    if (bytesRead == sizeof(DATA)) {  // Verifica se a quantidade de bytes lidos corresponde ao tamanho esperado da struct
      memcpy(&MyData, buffer, sizeof(DATA));  // Copia os bytes do buffer para a struct de dados

      uint8_t receivedChecksum = MyData.Checksum;           // Armazena o checksum recebido no pacote
      uint8_t calculatedChecksum = calculateChecksum(&MyData); // Calcula o checksum dos dados recebidos

      if (receivedChecksum == calculatedChecksum) {  // Verifica se o checksum recebido confere com o calculado
        Serial.println(">> Dados recebidos:");
        Serial.print("Contagem: "); Serial.println(MyData.Count);                              // Exibe o contador no monitor serial
        Serial.print("Tensão CC: "); Serial.print(MyData.TensaoVcc, 2); Serial.println("V");  // Exibe a tensão com 2 casas decimais

        // --- Publica no MQTT ---
        client.publish("Tensao_VCC", String(MyData.TensaoVcc, 2).c_str());  // Publica o valor da tensão no tópico MQTT "Tensao_VCC"
        Serial.println("Tensão VCC publicada no MQTT.");

        client.publish("Corrente_VCC", String(MyData.CorrenteDC, 3).c_str());  // Publica o valor da corrente no tópico MQTT "Corrente_VCC"
        Serial.println("Corrente DC publicada no MQTT.");

        sendAck(MyData.Count);  // Envia confirmação de recebimento ao Arduino transmissor
      } else {
        Serial.println("Dados corrompidos recebidos!");  // Exibe mensagem de erro caso o checksum não confira
      }
    }
  }

  delay(100);  // Pequena pausa para evitar sobrecarga no processador
}
